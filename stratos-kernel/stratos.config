# StratOS kernel config fragment (apply on top of LTS defconfig).
#
# Build: build-all-and-run.sh merges this after `make defconfig` then olddefconfig.
# Do not use stratos_minimal.config for that path — it is a legacy experiment (see file header there).

# Phase 4 required features.
CONFIG_LIVEPATCH=y
CONFIG_KEXEC=y
CONFIG_CHECKPOINT_RESTORE=y
CONFIG_DM_VERITY=y
CONFIG_ZRAM=y
CONFIG_ZSWAP=y
CONFIG_KSM=y
CONFIG_CGROUPS=y
CONFIG_CGROUP2_FS=y
CONFIG_OVERLAY_FS=y
CONFIG_INOTIFY_USER=y
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_VARS=y
CONFIG_EFIVAR_FS=y

# Filesystems for StratOS layout.
CONFIG_EROFS_FS=y
CONFIG_BTRFS_FS=y
CONFIG_XFS_FS=y
CONFIG_EXT4_FS=y
CONFIG_FAT_FS=y
CONFIG_VFAT_FS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y

# initramfs: loop-back mount of packed erofs; live ISO: hybrid CD + iso9660/udf.
CONFIG_BLK_DEV_LOOP=y
CONFIG_ISO9660_FS=y
CONFIG_UDF_FS=y

# Block/device: virtio-blk, SATA/AHCI, NVMe — match your target hardware.
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_NVME_CORE=y
CONFIG_SATA_AHCI=y

# Live session: optical / hybrid ISO block nodes; initramfs mounts iso9660/udf.
CONFIG_SCSI=y
CONFIG_BLK_DEV_SR=y

# devtmpfs (initramfs populates /dev before userspace)
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# Matches StratBoot / getty: ttyS0 serial and fbcon handoff.
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# VM-visible console handoff after EFI splash.
CONFIG_SYSFB_SIMPLEFB=y
CONFIG_DRM_SIMPLEDRM=y
CONFIG_DRM_FBDEV_EMULATION=y

# Clean boot screen defaults.
CONFIG_CMDLINE_BOOL=y
CONFIG_CMDLINE="quiet"
CONFIG_DEBUG_KERNEL=n
CONFIG_EARLY_PRINTK=n
CONFIG_PRINTK_TIME=n

# --- USB host + USB Ethernet dongles + Wi-Fi (built-in; rootfs does not load kernel modules) ---
CONFIG_USB=y
CONFIG_USB_PCI=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_OHCI_HCD=y
CONFIG_USB_STORAGE=y

CONFIG_USB_USBNET=y
CONFIG_USB_NET_CDCETHER=y
CONFIG_USB_NET_CDC_NCM=y
CONFIG_USB_NET_RNDIS_HOST=y
CONFIG_USB_RTL8152=y
CONFIG_USB_NET_AX88179_178A=y
CONFIG_USB_NET_ASIX=y

CONFIG_WIRELESS=y
CONFIG_CFG80211=y
CONFIG_MAC80211=y

CONFIG_WLAN_VENDOR_INTEL=y
CONFIG_IWLWIFI=y
CONFIG_IWLMVM=y
CONFIG_WLAN_VENDOR_REALTEK=y
CONFIG_RTW89=y
CONFIG_RTW88=y
CONFIG_RTW88_USB=y
CONFIG_MT76=y
CONFIG_MT7921U=y
CONFIG_RTL8XXXU=y
