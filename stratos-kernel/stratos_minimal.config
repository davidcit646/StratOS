# StratOS Minimal Kernel Configuration
# Phase 3: Kernel Tuning & Handoff
# Custom First: Direct Kconfig, no external helpers

# Architecture
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_X86=y
CONFIG_GENERIC_HWEIGHT=y
CONFIG_GENERIC_CALIBRATE_DELAY=y
CONFIG_ARCH_MAY_HAVE_PC_FDC=y
CONFIG_RWSEM_GENERIC_SPINLOCK=y

# EROFS filesystem support (built-in, not module)
CONFIG_EROFS_FS=y
CONFIG_EROFS_FS_XATTR=y
CONFIG_EROFS_FS_POSIX_ACL=y
CONFIG_EROFS_FS_SECURITY=y

# Block device support
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y
CONFIG_BLK_DEV_LOOP=y
CONFIG_BLK_DEV_SD=y

# PARTUUID root device resolution
CONFIG_PARTITION_ADVANCED=y
CONFIG_EFI_PARTITION=y

# PCI support (for UEFI GOP handoff compatibility)
CONFIG_PCI=y
CONFIG_PCI_DIRECT=y
CONFIG_PCI_DOMAINS=y

# EFI boot support
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_VARS=y
CONFIG_EFI_RUNTIME_WRAPPERS=y

# Bootloader parameter support
CONFIG_CMDLINE_BOOL=y
CONFIG_CMDLINE_OVERRIDE=y

# Disable modules (no module support)
CONFIG_MODULES=n
CONFIG_MODULE_SIG=n

# Basic device support
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_VT_HW_CONSOLE_BINDING=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# Early serial console (matches StratBoot console=ttyS0,115200)
CONFIG_EARLY_PRINTK=y
CONFIG_EARLY_PRINTK_SERIAL=y

# Memory management
CONFIG_FLATMEM=y
CONFIG_FLAT_NODE_MEM_MAP=y
CONFIG_SPARSEMEM_STATIC=y

# Process management
CONFIG_SMP=y
CONFIG_X86_LOCAL_APIC=y
CONFIG_X86_IO_APIC=y

# Security
CONFIG_SECURITY=y

# Disable non-essential features
CONFIG_SOUND=n
CONFIG_USB=n
CONFIG_WIRELESS=n
CONFIG_NETDEVICES=n
CONFIG_INPUT_MOUSE=n
CONFIG_INPUT_KEYBOARD=n
CONFIG_DRM=n
CONFIG_FB=n
CONFIG_VGA_ARB=n
CONFIG_WATCHDOG=n
CONFIG_RTC_CLASS=n
CONFIG_I2C=n
CONFIG_SPI=n
CONFIG_HWMON=n
CONFIG_THERMAL=n
CONFIG_CPU_FREQ=n
CONFIG_CPU_IDLE=n
CONFIG_PM=n
CONFIG_SUSPEND=n
CONFIG_HIBERNATION=n
CONFIG_ACPI=n
CONFIG_ATA=n
CONFIG_SCSI=n
CONFIG_MD=n
CONFIG_LVM=n
CONFIG_DM_MIRROR=n
CONFIG_DM_ZERO=n
CONFIG_DM_SNAPSHOT=n
CONFIG_NET=n
CONFIG_INET=n
CONFIG_NETFILTER=n
CONFIG_IPV6=n
CONFIG_NET_SCHED=n
CONFIG_NET_CLS=n
CONFIG_NET_CORE=n
CONFIG_UNIX=n
CONFIG_SYSVIPC=n
CONFIG_POSIX_MQUEUE=n
CONFIG_KEYS=n
CONFIG_KEYS_DEBUG=n
CONFIG_DEBUG_KERNEL=n
CONFIG_DEBUG_INFO=n
CONFIG_KALLSYMS=n
CONFIG_KPROBES=n
CONFIG_KGDB=n
CONFIG_KEXEC=n
CONFIG_CRASH_DUMP=n
CONFIG_PROC_FS=y
CONFIG_PROC_SYSCTL=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
